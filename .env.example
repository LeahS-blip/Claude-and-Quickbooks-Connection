# ---- QuickBooks Online app credentials ----
# Create an app at https://developer.intuit.com  ->  My Apps  ->  Keys & credentials
QB_CLIENT_ID=your_client_id_here
QB_CLIENT_SECRET=your_client_secret_here

# "sandbox" while testing against a sandbox company, "production" for a real company.
QB_ENVIRONMENT=sandbox

# Redirect URI. Must EXACTLY match one of the Redirect URIs configured in your Intuit app.
# The default below works for the local one-time `npm run auth` flow.
QB_REDIRECT_URI=http://localhost:3000/callback

# QuickBooks API minor version (controls field availability). 75 is current as of 2026.
QB_MINOR_VERSION=75

# Where the OAuth tokens are stored after `npm run auth`. Leave as-is unless you have a reason.
QB_TOKENS_PATH=./tokens.json
